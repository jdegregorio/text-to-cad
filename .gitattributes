# Keep CAD exchange files and generated render/topology assets out of normal git object history.
*.step filter=lfs diff=lfs merge=lfs -text
*.stp filter=lfs diff=lfs merge=lfs -text
*.stl filter=lfs diff=lfs merge=lfs -text
**/.*.step/**/*.glb filter=lfs diff=lfs merge=lfs -text
**/.*.step/topology.bin filter=lfs diff=lfs merge=lfs -text
**/.*.step/topology.json filter=lfs diff=lfs merge=lfs -text
